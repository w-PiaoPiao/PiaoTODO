{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri-config-schema/refs/heads/main/tauri-conf.schema.json",
  "productName": "LiteToDo",
  "version": "0.1.0",
  "identifier": "com.litetodo.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "LiteToDo",
        "width": 360,
        "height": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
